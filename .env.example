# GitHub Copilot API Configuration
# Get your API key from: https://github.com/settings/copilots
COPILOT_API_KEY=your-github-copilot-api-key-here

# Optional: Custom API URL (defaults to official GitHub API)
# COPILOT_API_URL=https://api.github.com/copilot

# Optional: Enable auto-save of conversations
# AUTO_SAVE=false

# Optional: Maximum message length (default: 4096)
# MAX_MESSAGE_LENGTH=4096
