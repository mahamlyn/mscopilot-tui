# Microsoft Entra ID (Azure AD) App Registration
# Register at: https://entra.microsoft.com → App registrations → New registration
# Docs: https://learn.microsoft.com/en-us/microsoft-365/copilot/extensibility/copilot-apis-overview

# Required: Your Azure AD / Entra tenant ID (or "common" for multi-tenant)
TENANT_ID=your-tenant-id-here

# Required: The Application (client) ID from your app registration
CLIENT_ID=your-client-id-here

# Optional: Only needed for confidential client (app-only) flows.
# The Device Code Flow used by this TUI does NOT require a client secret.
# CLIENT_SECRET=your-client-secret-here

# Optional: Override the default Microsoft Graph Copilot endpoint
# GRAPH_BASE_URL=https://graph.microsoft.com/beta/copilot

# Optional: Enable auto-save of conversations
# AUTO_SAVE=false

# Optional: Maximum message length (default: 4096)
# MAX_MESSAGE_LENGTH=4096
